      <aliases enabled='yes' />
      <column caption='GLOBAL PEACE INDEX' datatype='real' name='[Calculation_2295991402943135745]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Indicator Code] = &apos;PV.EST&apos; THEN [Value] END' />
      </column>
      <column caption='GLOBAL INFLATION RATE' datatype='real' name='[Calculation_2295991402949586948]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Indicator Code] = &apos;FP.CPI.TOTL.ZG&apos; THEN [Value] END' />
      </column>
      <column caption='GLOBAL GDP GROWTH' datatype='real' name='[Calculation_2295991402950336518]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Indicator Code] = &apos;NY.GDP.MKTP.KD.ZG&apos; THEN [Value] END' />
      </column>
      <column caption='THE STABILITY GAP' datatype='real' name='[Calculation_2295991402950574087]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{MAX(IF [Indicator Code] = &apos;PV.EST&apos; THEN [Value] END)} - {MIN(IF [Indicator Code] = &apos;PV.EST&apos; THEN [Value] END)}' />
      </column>
      <column caption='GLOBAL MEDICAL CAPACITY' datatype='real' name='[Calculation_2295991402950778888]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Indicator Code] = &apos;SH.MED.PHYS.ZS&apos; THEN [Value] END' />
      </column>
      <column caption='the economic titan' datatype='real' name='[Calculation_2295991402951024649]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Indicator Code] = &apos;NY.GDP.MKTP.KD.ZG&apos; THEN [Value] END' />
      </column>
      <column caption='ELECTRICITY ACESS RATE' datatype='real' name='[Calculation_2295991402964410380]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Indicator Code] = &apos;EG.ELC.ACCS.ZS&apos; THEN [Value] END' />
      </column>
      <column caption='INTERNET PENTRATION RATE' datatype='real' name='[Calculation_2295991402965852173]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Indicator Code] = &apos;IT.NET.USER.ZS&apos; THEN [Value] END' />
      </column>
      <column caption='CARBON FOOTPRINT' datatype='real' name='[Calculation_2295991402969653263]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Indicator Code] = &apos;EN.GHG.CO2.PC.CE.AR5&apos; THEN [Value] END' />
      </column>
      <column caption='COMPOSITE SCORE' datatype='real' name='[Calculation_2295991402982248464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Normalized Value])' />
      </column>
      <column caption='RISK CATEGORY' datatype='string' name='[Calculation_2295991403036667921]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2295991402982248464] &lt; 0.5 THEN &quot;High Risk&quot; ELSEIF [Calculation_2295991402982248464] &lt; 0.75 THEN &quot;Medium Risk&quot; ELSE &quot;Low Risk&quot; END' />
      </column>
      <column caption='Undernourishment %' datatype='real' name='[Calculation_2295991403037204498]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Indicator Code] = &apos;SN.ITK.DEFC.ZS&apos; THEN [Value] END)' />
      </column>
      <column caption='Global Rank' datatype='integer' name='[Calculation_2295991403037515795]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE([Calculation_2295991402982248464], &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='HEALTH SCORE' datatype='real' name='[Calculation_2295991403041030165]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Indicator Code] = &apos;SP.DYN.LE00.IN&apos; THEN [Normalized Value] END)' />
      </column>
      <column caption='Double Risk Flag' datatype='string' name='[Calculation_2295991403041325078]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2295991403041030165] &lt; 0.4 AND [Calculation_2295991403037204498] &gt; 20 THEN &quot;Critical: Double Risk&quot; ELSE &quot;Standard&quot; END' />
      </column>
      <column caption='current year vs. prior' datatype='real' name='[Calculation_2729744343114424320]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Year] = {MAX([Year])} THEN [Value] END)&#13;&#10;- AVG(IF [Year] = {MAX([Year])}-1 THEN [Value] END)' />
      </column>
      <column caption='access tier' datatype='string' name='[Calculation_2729744343114797057]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG(IF [Indicator Code]=&apos;EG.ELC.ACCS.ZS&apos; THEN [Value] END) &gt;= 95 THEN &apos;Full Access&apos;&#13;&#10;ELSEIF AVG(IF [Indicator Code]=&apos;EG.ELC.ACCS.ZS&apos; THEN [Value] END) &gt;= 50 THEN &apos;Partial Access&apos;&#13;&#10;ELSE &apos;Low Access&apos; END' />
      </column>
      <column caption='KPI BAN Format' datatype='string' name='[Calculation_2729744343118909443]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ZN([Calculation_2295991402982248464]) - LOOKUP(ZN([Calculation_2295991402982248464]), -1) &gt; 0 THEN &quot;▲ &quot; + STR(ROUND(ZN([Calculation_2295991402982248464]) - LOOKUP(ZN([Calculation_2295991402982248464]), -1),2)) ELSE &quot;▼ &quot; + STR(ROUND(ABS(ZN([Calculation_2295991402982248464]) - LOOKUP(ZN([Calculation_2295991402982248464]), -1)),2)) END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Digital Pct' datatype='real' name='[Calculation_2729744343121145860]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Domain]=&apos;Digital Infrastructure&apos; THEN [Normalized Value] END) * 100' />
      </column>
      <column caption='Remainder' datatype='real' name='[Calculation_2729744343121453061]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='100 - [Calculation_2729744343121145860]' />
      </column>
      <column caption='avg food price' datatype='real' name='[Calculation_799388955771326464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Price Index])' />
      </column>
      <column caption='domain volatity' datatype='real' name='[Calculation_799388955771777025]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='STDEV([Normalized Value])' />
      </column>
      <column caption='political stability score' datatype='real' name='[Calculation_799388955772432386]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Indicator Code] = &apos;PV.EST&apos; THEN [Value] END)' />
      </column>
      <column caption='price shock 2022' datatype='real' name='[Calculation_799388955772686339]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG(IF [Year] = 2022 THEN [Price Index] END) - &#13;&#10; AVG(IF [Year] = 2020 THEN [Price Index] END)) /&#13;&#10; AVG(IF [Year] = 2020 THEN [Price Index] END) * 100' />
      </column>
      <column caption='resilience tier' datatype='string' name='[Calculation_799388955772956676]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Normalized Value]) &gt;= 0.70 THEN &quot;High Resilience&quot;&#13;&#10;ELSEIF AVG([Normalized Value]) &gt;= 0.55 THEN &quot;Medium-High&quot;&#13;&#10;ELSEIF AVG([Normalized Value]) &gt;= 0.40 THEN &quot;Medium-Low&quot;&#13;&#10;ELSE &quot;Low Resilience&quot;&#13;&#10;END' />
      </column>
      <column caption='resilience score' datatype='real' name='[Calculation_799388955780972549]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Normalized Value])' />
      </column>
      <column caption='risk flag' datatype='string' name='[Calculation_799388955789156358]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Normalized Value]) &lt; 0.5 THEN &quot;High Risk&quot; ELSE &quot;Stable&quot; END' />
      </column>
      <column caption='price index volatity' datatype='real' name='[Calculation_799388955858739212]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='STDEV([Price Index])' />
      </column>
